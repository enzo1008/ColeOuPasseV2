<script>

// ════════════════════════════════════════════════════════════
// UTILS
// ════════════════════════════════════════════════════════════
function shuffle(arr){const a=[…arr];for(let i=a.length-1;i>0;i–){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}return a;}
function shuffleOpts(q){return{…q,o:shuffle(q.o)};}
function escH(s){return String(s).replace(/&/g,’&’).replace(/</g,’<’).replace(/>/g,’>’).replace(/”/g,’"’);}
function delay(ms){return new Promise(r=>setTimeout(r,ms));}
function fmtTime(ms){const s=Math.round(ms/1000);return s<60?s+‘s’:Math.floor(s/60)+‘m’+String(s%60).padStart(2,‘0’)+‘s’;}
function normName(n){return n.trim().toLowerCase();}
function usGrade(pct){
if(pct===100)return{letter:‘A+’,gpa:‘4.0’,color:’#ffd700’,label:‘Perfect Score!’};
if(pct>=93)return{letter:‘A’,gpa:‘4.0’,color:’#22c55e’,label:‘Excellent’};
if(pct>=90)return{letter:‘A\u2212’,gpa:‘3.7’,color:’#22c55e’,label:‘Excellent’};
if(pct>=87)return{letter:‘B+’,gpa:‘3.3’,color:’#86efac’,label:‘Above Average’};
if(pct>=83)return{letter:‘B’,gpa:‘3.0’,color:’#86efac’,label:‘Good’};
if(pct>=80)return{letter:‘B\u2212’,gpa:‘2.7’,color:’#86efac’,label:‘Good’};
if(pct>=77)return{letter:‘C+’,gpa:‘2.3’,color:’#f59e0b’,label:‘Average’};
if(pct>=73)return{letter:‘C’,gpa:‘2.0’,color:’#f59e0b’,label:‘Average’};
if(pct>=70)return{letter:‘C\u2212’,gpa:‘1.7’,color:’#f59e0b’,label:‘Below Average’};
if(pct>=67)return{letter:‘D+’,gpa:‘1.3’,color:’#ef4444’,label:‘Passing (barely)’};
if(pct>=63)return{letter:‘D’,gpa:‘1.0’,color:’#ef4444’,label:‘Passing (barely)’};
if(pct>=60)return{letter:‘D\u2212’,gpa:‘0.7’,color:’#ef4444’,label:‘Passing (barely)’};
return{letter:‘F’,gpa:‘0.0’,color:’#7f1d1d’,label:‘Failed’};
}

// ════════════════════════════════════════════════════════════
// TEMA (dia / noite)
// ════════════════════════════════════════════════════════════
const THEME_KEY=‘cop_theme’;
function applyTheme(t){
const r=document.documentElement;
if(t===‘light’){
r.style.setProperty(’–bg’,’#f0f0f0’);
r.style.setProperty(’–card’,’#ffffff’);
r.style.setProperty(’–card2’,’#e8e8e8’);
r.style.setProperty(’–border’,’#cccccc’);
r.style.setProperty(’–text’,’#111111’);
r.style.setProperty(’–muted’,’#555555’);
r.style.setProperty(’–dim’,’#888888’);
} else {
r.style.setProperty(’–bg’,’#0a0a0a’);
r.style.setProperty(’–card’,’#111111’);
r.style.setProperty(’–card2’,’#181818’);
r.style.setProperty(’–border’,’#252525’);
r.style.setProperty(’–text’,’#e5e5e5’);
r.style.setProperty(’–muted’,’#888888’);
r.style.setProperty(’–dim’,’#444444’);
}
// Update scrollbar for light theme
const style=document.getElementById(‘scrollbar-style’)||document.createElement(‘style’);
style.id=‘scrollbar-style’;
style.textContent=t===‘light’?’::-webkit-scrollbar-track{background:#ddd}::-webkit-scrollbar-thumb{background:#aaa}’:’’;
document.head.appendChild(style);
}
function getTheme(){return localStorage.getItem(THEME_KEY)||‘dark’;}
function setTheme(t){localStorage.setItem(THEME_KEY,t);applyTheme(t);}
function toggleTheme(){setTheme(getTheme()===‘dark’?‘light’:‘dark’);renderSettings();}

// ════════════════════════════════════════════════════════════
// AUTH — case-insensitive, photo de perfil
// ════════════════════════════════════════════════════════════
const AUTH_KEY=‘cop_users’;
const SESSION_KEY=‘cop_session’;

function getUsers(){try{return JSON.parse(localStorage.getItem(AUTH_KEY)||’{}’);}catch{return {};}}
function saveUsers(u){localStorage.setItem(AUTH_KEY,JSON.stringify(u));}
function getSession(){return localStorage.getItem(SESSION_KEY)||null;}
function saveSession(key){localStorage.setItem(SESSION_KEY,key);}
function clearSession(){localStorage.removeItem(SESSION_KEY);}

// Returns the canonical key (lowercased) for a display name
function userKey(name){return normName(name);}

function doLogin(){
const rawName=document.getElementById(‘login-name’).value.trim();
const pass=document.getElementById(‘login-pass’).value;
const err=document.getElementById(‘login-err’);
err.textContent=’’;
if(rawName.length<2){err.textContent=‘Nome deve ter ao menos 2 caracteres.’;return;}
if(pass.length<4){err.textContent=‘Senha deve ter ao menos 4 caracteres.’;return;}
const users=getUsers();
const key=userKey(rawName);
if(users[key]){
if(users[key].pass!==btoa(unescape(encodeURIComponent(pass)))){err.textContent=‘Senha incorreta.’;return;}
} else {
users[key]={displayName:rawName,pass:btoa(unescape(encodeURIComponent(pass))),perfects:{},photo:null,created:Date.now()};
saveUsers(users);
}
saveSession(key);
G.currentUser=key;
G.displayName=users[key].displayName||rawName;
G.perfects=users[key].perfects||{};
renderMenu();
}

function doLogout(){
clearSession();
G.currentUser=null;G.displayName=null;
stopTimers();stopQTimer();
showScreen(‘login’);
}

function loadUserSession(){
const key=getSession();if(!key)return false;
const users=getUsers();if(!users[key])return false;
G.currentUser=key;
G.displayName=users[key].displayName||key;
G.perfects=users[key].perfects||{};
return true;
}

function savePerfect(nivel){
const users=getUsers();
if(users[G.currentUser]){
users[G.currentUser].perfects=users[G.currentUser].perfects||{};
users[G.currentUser].perfects[nivel]=true;
saveUsers(users);
}
}

function savePhoto(dataUrl){
const users=getUsers();
if(users[G.currentUser]){users[G.currentUser].photo=dataUrl;saveUsers(users);}
G.photo=dataUrl;
updateAvatarUI();
}

function getPhoto(){
const users=getUsers();
return users[G.currentUser]?users[G.currentUser].photo||null:null;
}

function changePassword(){
const cur=document.getElementById(‘cfg-cur-pass’).value;
const nw=document.getElementById(‘cfg-new-pass’).value;
const err=document.getElementById(‘cfg-pass-err’);
err.textContent=’’;
const users=getUsers();
const u=users[G.currentUser];
if(!u){err.textContent=‘Usuário não encontrado.’;return;}
if(u.pass!==btoa(unescape(encodeURIComponent(cur)))){err.textContent=‘Senha atual incorreta.’;return;}
if(nw.length<4){err.textContent=‘Nova senha deve ter ao menos 4 caracteres.’;return;}
u.pass=btoa(unescape(encodeURIComponent(nw)));
saveUsers(users);
err.style.color=‘var(–green)’;err.textContent=‘Senha alterada com sucesso! ✓’;
document.getElementById(‘cfg-cur-pass’).value=’’;
document.getElementById(‘cfg-new-pass’).value=’’;
setTimeout(()=>{err.textContent=’’;err.style.color=‘var(–red)’;},2500);
}

function updateAvatarUI(){
const photo=getPhoto();
[‘avatar-menu’,‘avatar-cfg’].forEach(id=>{
const el=document.getElementById(id);
if(!el)return;
if(photo){el.style.backgroundImage=`url(${photo})`;el.style.backgroundSize=‘cover’;el.style.backgroundPosition=‘center’;el.textContent=’’;}
else{el.style.backgroundImage=’’;el.textContent=(G.displayName||G.currentUser||’?’)[0].toUpperCase();}
});
}

// ════════════════════════════════════════════════════════════
// LEADERBOARD
// ════════════════════════════════════════════════════════════
const LB_KEY=‘cop_leaderboard’;
function getLB(){try{return JSON.parse(localStorage.getItem(LB_KEY)||’{}’);}catch{return {};}}
function saveLB(lb){localStorage.setItem(LB_KEY,JSON.stringify(lb));}

function addLBEntry(nivel,score,timeMs,pct){
const lb=getLB();
if(!lb[nivel])lb[nivel]=[];
lb[nivel].push({name:G.displayName||G.currentUser,score,timeMs,pct,date:Date.now()});
lb[nivel].sort((a,b)=>b.score-a.score||(a.timeMs-b.timeMs));
lb[nivel]=lb[nivel].slice(0,20);
saveLB(lb);
}

function renderLeaderboard(nivel,myScore,myTime){
const lb=getLB();
const entries=lb[nivel]||[];
document.getElementById(‘lb-level-label’).textContent=CONFIG[nivel]?CONFIG[nivel].label:nivel;
const tbody=document.getElementById(‘lb-body’);tbody.innerHTML=’’;
if(!entries.length){tbody.innerHTML=’<tr><td colspan="4" class="lb-empty">Nenhuma pontuação ainda. Seja o primeiro! 🏆</td></tr>’;return;}
entries.forEach((e,i)=>{
const isMe=e.name===(G.displayName||G.currentUser)&&Math.abs(e.score-myScore)<1&&Math.abs(e.timeMs-myTime)<5000;
const tr=document.createElement(‘tr’);if(isMe)tr.className=‘me’;
const rk=i===0?‘🥇’:i===1?‘🥈’:i===2?‘🥉’:’#’+(i+1);
const rkClass=i===0?‘gold’:i===1?‘silver’:i===2?‘bronze’:’’;
tr.innerHTML=`<td class="lb-rank ${rkClass}">${rk}</td><td class="lb-name">${escH(e.name)}${isMe?' <span style="color:#a78bfa;font-size:9px">(você)</span>':''}</td><td class="lb-score">${e.score}</td><td class="lb-time">${fmtTime(e.timeMs)}</td>`;
tbody.appendChild(tr);
});
}

// ════════════════════════════════════════════════════════════
