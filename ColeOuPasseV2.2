<!DOCTYPE html>

<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>ColeOuPasseV2</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#0a0a0a;--card:#111;--card2:#181818;--border:#252525;
  --text:#e5e5e5;--muted:#888;--dim:#444;
  --green:#22c55e;--yellow:#f59e0b;--red:#ef4444;
  --purple:#a855f7;--orange:#f97316;--gold:#ffd700;
  --w:480px;--r:14px;
}
html,body{min-height:100%;background:var(--bg);color:var(--text);font-family:'Courier New',Courier,monospace;transition:background .3s,color .3s;}
body{min-height:100vh;display:flex;flex-direction:column;align-items:center;padding:14px 12px 48px;}
::-webkit-scrollbar{width:4px;}::-webkit-scrollbar-track{background:#1a1a1a;}::-webkit-scrollbar-thumb{background:#333;border-radius:4px;}
.screen{display:none;width:100%;max-width:var(--w);}
.screen.active{display:flex;flex-direction:column;align-items:stretch;}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.35}}
@keyframes goldPulse{0%,100%{box-shadow:0 0 12px rgba(255,215,0,.35)}50%{box-shadow:0 0 26px rgba(255,215,0,.65)}}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-7px)}75%{transform:translateX(7px)}}
@keyframes glitch{0%,100%{filter:none}50%{filter:hue-rotate(180deg) saturate(4) brightness(1.3)}}
@keyframes fadeUp{from{opacity:0;transform:translateX(-50%) translateY(6px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}
@keyframes cheatIn{from{opacity:0;transform:scale(.93)}to{opacity:1;transform:scale(1)}}
@keyframes timerPulse{0%,100%{box-shadow:none}50%{box-shadow:0 0 10px rgba(239,68,68,.6)}}

/* Cards */
.card{width:100%;background:var(–card);border:1.5px solid #5b5ef4;border-radius:var(–r);padding:22px 18px;text-align:center;margin-top:10px;transition:background .3s,border-color .3s;}
.card-game{width:100%;background:var(–card);border:1.5px solid var(–border);border-radius:var(–r);padding:14px 13px;position:relative;margin-top:8px;}

/* Login */
.login-icon{font-size:52px;margin-bottom:8px;}
.login-title{font-size:20px;font-weight:900;letter-spacing:2px;color:var(–text);margin-bottom:4px;}
.login-sub{font-size:11px;color:var(–muted);margin-bottom:18px;}
.input-group{display:flex;flex-direction:column;gap:10px;margin-bottom:16px;}
.input-wrap input{width:100%;background:var(–card2);border:1.5px solid var(–border);border-radius:10px;padding:11px 14px;font-size:13px;color:var(–text);font-family:‘Courier New’,monospace;outline:none;transition:border-color .2s,background .3s;}
.input-wrap input:focus{border-color:#5b5ef4;}
.input-wrap input::placeholder{color:var(–dim);}
.login-btn{width:100%;background:linear-gradient(135deg,#5b5ef4,#a78bfa);border:none;border-radius:10px;padding:13px;font-size:14px;font-weight:900;color:#fff;font-family:‘Courier New’,monospace;cursor:pointer;letter-spacing:1px;transition:opacity .2s;}
.login-btn:hover{opacity:.9;}
.login-err{font-size:11px;color:var(–red);margin-top:8px;min-height:16px;}
.login-hint{font-size:10px;color:var(–dim);margin-top:10px;line-height:1.7;}

/* AI Badge */
.ai-badge{display:inline-flex;align-items:center;gap:6px;background:linear-gradient(135deg,#1a0a2e,#0d1a2e);border:1px solid #5b5ef4;border-radius:20px;padding:5px 14px;font-size:10px;color:#a78bfa;font-weight:700;letter-spacing:.5px;margin-bottom:12px;}
.ai-dot{width:6px;height:6px;border-radius:50%;background:#a78bfa;animation:blink 1.5s infinite;}

/* Menu */
.title{font-size:21px;font-weight:900;letter-spacing:3px;color:var(–text);margin-bottom:4px;}
.sub{font-size:11px;color:var(–dim);letter-spacing:1px;margin-bottom:8px;}
.desc{font-size:12px;color:var(–muted);line-height:1.7;margin-bottom:14px;}

/* User bar */
.user-bar{display:flex;align-items:center;gap:10px;background:var(–card2);border:1px solid var(–border);border-radius:12px;padding:8px 12px;margin-bottom:12px;}
.avatar{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#5b5ef4,#a78bfa);display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:900;color:#fff;flex-shrink:0;overflow:hidden;background-size:cover;background-position:center;}
.user-info{flex:1;min-width:0;}
.user-name{color:#a78bfa;font-weight:700;font-size:12px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.user-sub{font-size:9px;color:var(–dim);}
.user-bar-btns{display:flex;gap:6px;flex-shrink:0;}
.icon-btn{background:var(–card);border:1px solid var(–border);border-radius:8px;padding:5px 9px;font-size:13px;cursor:pointer;transition:background .2s;color:var(–text);}
.icon-btn:hover{background:var(–border);}

/* Level grid */
.level-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:14px;width:100%;}
.level-btn{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;border:2px solid;border-radius:12px;padding:14px 10px;cursor:pointer;transition:transform .15s,box-shadow .3s;color:var(–text);font-family:‘Courier New’,monospace;background:transparent;width:100%;min-height:84px;}
.level-btn:hover{transform:scale(1.03);}
.level-btn:active{transform:scale(.97);}
.level-btn.rush{grid-column:1/-1;min-height:60px;}
.level-btn.perfect{animation:goldPulse 2s infinite;}
.level-name{font-size:13px;font-weight:900;display:flex;align-items:center;gap:5px;flex-wrap:wrap;justify-content:center;}
.level-desc{font-size:9.5px;color:var(–muted);line-height:1.4;text-align:center;}
.perfect-badge{font-size:10px;font-weight:900;color:var(–gold);}
.hint{background:var(–card2);border:1px solid var(–border);border-radius:10px;padding:10px 13px;font-size:10.5px;color:var(–muted);line-height:1.8;text-align:left;width:100%;}
.hint b{color:var(–text);}

/* Loading */
.loading-card{width:100%;background:var(–card);border:1.5px solid #5b5ef4;border-radius:var(–r);padding:34px 22px;text-align:center;margin-top:10px;}
.spinner{width:44px;height:44px;border:3px solid var(–border);border-top-color:#a78bfa;border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 16px;}
.loading-title{font-size:14px;font-weight:900;color:#a78bfa;margin-bottom:7px;letter-spacing:1px;}
.loading-sub{font-size:11px;color:var(–muted);margin-bottom:14px;}
.loading-steps{display:flex;flex-direction:column;gap:7px;}
.step{display:flex;align-items:center;gap:9px;background:var(–card2);border-radius:8px;padding:8px 12px;font-size:11px;color:var(–muted);border:1px solid transparent;transition:all .3s;}
.step.active{color:#a78bfa;border-color:rgba(167,139,250,.3);animation:blink 1s infinite;}
.step.done{color:var(–green);border-color:rgba(34,197,94,.3);}
.step.wait{opacity:.3;}
.step-ico{font-size:14px;flex-shrink:0;}

/* Game top bar */
.top-bar{display:flex;gap:4px;margin-bottom:9px;width:100%;}
.top-stat{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;background:var(–card2);border-radius:9px;padding:5px 3px;min-width:0;}
.stat-label{font-size:7.5px;color:var(–dim);letter-spacing:.4px;margin-bottom:2px;white-space:nowrap;text-transform:uppercase;}
.stat-val{font-size:13px;font-weight:900;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:100%;}

/* Timer */
.timer-bar{display:flex;align-items:center;gap:6px;margin-bottom:8px;}
.timer-label{font-size:9px;color:var(–dim);min-width:46px;flex-shrink:0;}
.timer-track{flex:1;height:6px;background:var(–card2);border-radius:99px;overflow:hidden;}
.timer-fill{height:100%;border-radius:99px;transition:width .25s linear,background .4s;}
.timer-num{font-size:11px;font-weight:900;min-width:28px;text-align:right;flex-shrink:0;}
.timer-urgent{animation:timerPulse .5s infinite;}

/* Susp */
.susp-row{display:flex;align-items:center;gap:6px;margin-bottom:8px;}
.susp-label{font-size:9px;color:var(–dim);min-width:54px;flex-shrink:0;}
.susp-track{flex:1;height:6px;background:var(–card2);border-radius:99px;overflow:hidden;}
.susp-fill{height:100%;border-radius:99px;transition:width .3s,background .4s;}
.susp-pct{font-size:10px;font-weight:900;min-width:30px;text-align:right;flex-shrink:0;}

/* Fiscal banner */
.fiscal-banner{border:1px solid;border-radius:7px;padding:6px 10px;font-size:10.5px;font-weight:700;margin-bottom:8px;text-align:center;letter-spacing:.3px;transition:all .4s;}

/* Dots */
.dot-row{display:flex;gap:3px;margin-bottom:9px;justify-content:center;flex-wrap:wrap;align-items:center;}
.dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;transition:background .3s,box-shadow .3s;}
.dot-extra{font-size:8.5px;color:var(–dim);margin-left:3px;}

/* Question */
.q-box{background:var(–card2);border-radius:10px;padding:12px 11px;margin-bottom:9px;border-left:3px solid;}
.q-label{font-size:8.5px;letter-spacing:.7px;margin-bottom:5px;text-transform:uppercase;}
.q-text{font-size:13.5px;font-weight:700;line-height:1.55;color:var(–text);}
.q-ai-tag{display:none;align-items:center;gap:4px;background:rgba(167,139,250,.12);border:1px solid rgba(167,139,250,.3);border-radius:9px;padding:2px 7px;font-size:8.5px;color:#a78bfa;font-weight:700;margin-bottom:5px;width:fit-content;}

/* Options */
.opt-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:9px;}
.opt-btn{width:100%;min-height:50px;display:flex;align-items:center;background:var(–card2);color:var(–text);border:1.5px solid var(–border);border-radius:9px;padding:9px 8px;font-size:11.5px;font-family:‘Courier New’,monospace;font-weight:600;text-align:left;cursor:pointer;transition:border-color .15s,background .15s;line-height:1.4;word-break:break-word;hyphens:auto;}
.opt-btn:hover:not(:disabled){border-color:var(–lvl-color,#5b5ef4);background:var(–lvl-bg,rgba(91,94,244,.1));}
.opt-btn:disabled{cursor:default;opacity:.85;}
.opt-btn.correct{border-color:var(–green)!important;background:#0d2414!important;color:#4ade80!important;}
.opt-btn.wrong{border-color:var(–red)!important;background:#2a0808!important;color:#f87171!important;}
.opt-letter{color:var(–dim);font-size:9px;margin-right:4px;flex-shrink:0;}

/* Cheat */
.cheat-zone{display:flex;flex-direction:column;align-items:center;gap:7px;min-height:52px;padding-bottom:3px;}
.cheat-btn{color:#fbbf24;border:1.5px dashed #fbbf24;border-radius:10px;padding:8px 20px;font-size:12px;font-family:‘Courier New’,monospace;font-weight:900;letter-spacing:1px;cursor:pointer;background:#1a1200;transition:opacity .2s,background .2s;}
.cheat-btn.open{border-style:solid;background:#231a00;}
.cheat-btn:disabled{opacity:.35;cursor:not-allowed;}
.cheat-card{width:100%;background:#1c1500;border:1.5px solid #f59e0b;border-radius:10px;padding:9px 16px;text-align:center;display:none;animation:cheatIn .15s ease;}
.cheat-card.visible{display:block;}
.cheat-warn{font-size:9px;color:#f59e0b;margin-bottom:3px;letter-spacing:1px;}
.cheat-answer{font-size:15px;font-weight:900;color:#fbbf24;word-break:break-word;}
.cheat-hint{font-size:9px;color:#78350f;margin-top:3px;}
.back-btn{margin-top:10px;background:none;border:none;color:var(–dim);font-size:10px;cursor:pointer;font-family:‘Courier New’,monospace;text-decoration:underline;display:block;width:100%;text-align:center;padding:4px;}
.back-btn:hover{color:var(–muted);}

/* Toast */
#toast{position:fixed;bottom:16px;left:50%;transform:translateX(-50%);background:var(–card2);border:1px solid var(–border);border-radius:8px;padding:7px 16px;font-size:11.5px;font-weight:700;white-space:normal;word-break:break-word;max-width:min(86vw,400px);z-index:9999;pointer-events:none;text-align:center;display:none;animation:fadeUp .2s ease;}

/* Stats / grade */
.stats-box{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin:10px 0;width:100%;}
.stat-item{background:var(–card2);border-radius:10px;padding:9px 11px;display:flex;flex-direction:column;gap:2px;font-size:10.5px;color:var(–muted);}
.stat-item b{color:var(–text);font-size:13px;}
.grade-card{display:flex;gap:14px;align-items:center;justify-content:center;border:2px solid;border-radius:13px;padding:12px 20px;margin:10px auto;width:fit-content;max-width:100%;}
.grade-letter{font-size:44px;font-weight:900;line-height:1;}
.grade-info{display:flex;flex-direction:column;align-items:flex-start;gap:3px;}
.grade-info span{font-size:10.5px;color:var(–muted);}
.grade-info .grade-label{font-size:11.5px;font-weight:700;}
.scale-wrap{display:flex;gap:3px;flex-wrap:wrap;justify-content:center;margin:7px 0 4px;width:100%;}
.scale-item{border:1px solid;border-radius:5px;padding:2px 6px;font-size:8.5px;font-weight:700;}

/* Leaderboard */
.leaderboard-wrap{width:100%;margin:12px 0;}
.lb-title{font-size:12px;color:#a78bfa;font-weight:900;margin-bottom:8px;display:flex;align-items:center;gap:6px;}
.lb-table{width:100%;border-collapse:collapse;font-size:11px;}
.lb-table th{color:var(–dim);font-size:9px;letter-spacing:.5px;padding:5px 8px;text-align:left;border-bottom:1px solid var(–border);}
.lb-table td{padding:7px 8px;border-bottom:1px solid var(–card2);color:var(–muted);}
.lb-table tr:hover td{background:var(–card2);}
.lb-table tr.me td{color:var(–text);background:rgba(91,94,244,.08);}
.lb-rank{font-weight:900;color:var(–dim);width:24px;}
.lb-rank.gold{color:var(–gold);}
.lb-rank.silver{color:#aaa;}
.lb-rank.bronze{color:#cd7f32;}
.lb-name{font-weight:700;}
.lb-score{color:var(–green);font-weight:700;text-align:right;}
.lb-time{color:var(–yellow);text-align:right;}
.lb-empty{text-align:center;color:var(–dim);padding:20px;font-size:11px;}

/* Gabarito */
.gab-header{font-size:10.5px;color:var(–dim);margin:10px 0 5px;text-align:left;width:100%;}
.gab-list{width:100%;display:flex;flex-direction:column;gap:3px;max-height:280px;overflow-y:auto;padding-right:2px;}
.gab-row{width:100%;display:flex;gap:5px;align-items:center;padding:6px 9px;background:var(–card2);border:1px solid var(–border);border-radius:8px;cursor:pointer;font-family:‘Courier New’,monospace;transition:background .2s;text-align:left;}
.gab-row:hover{background:var(–border);}
.gab-row.correct-row{border-color:rgba(34,197,94,.27);}
.gab-row.wrong-row{border-color:rgba(239,68,68,.27);}
.gab-row.expanded{border-radius:8px 8px 0 0;}
.gab-num{color:var(–dim);font-size:9px;min-width:22px;flex-shrink:0;}
.gab-q{flex:1;font-size:10.5px;color:var(–muted);line-height:1.4;}
.gab-arr{color:var(–dim);font-size:9px;flex-shrink:0;}
.gab-ai{font-size:9px;color:#a78bfa;flex-shrink:0;}
.gab-cheat{font-size:9px;color:#f59e0b;flex-shrink:0;}
.gab-detail{background:var(–card);border:1px solid var(–border);border-top:none;border-radius:0 0 8px 8px;padding:6px 8px;flex-direction:column;gap:4px;display:none;}
.gab-detail.open{display:flex;}
.gab-opt{display:flex;gap:5px;align-items:flex-start;padding:5px 8px;border:1px solid var(–border);border-radius:7px;font-size:10.5px;color:var(–muted);background:var(–card2);word-break:break-word;}
.gab-opt.correct-opt{border-color:var(–green)!important;background:#0d2414!important;color:#4ade80!important;}
.gab-opt.wrong-opt{border-color:var(–red)!important;background:#2a0808!important;color:#f87171!important;}
.gab-opt-letter{font-size:9px;min-width:14px;flex-shrink:0;margin-top:1px;}
.gab-opt-tag{font-size:9px;font-weight:700;margin-left:auto;flex-shrink:0;white-space:nowrap;}

/* Settings */
.cfg-section{background:var(–card2);border:1px solid var(–border);border-radius:12px;padding:14px;margin-bottom:12px;text-align:left;}
.cfg-title{font-size:11px;color:var(–dim);letter-spacing:.5px;text-transform:uppercase;margin-bottom:10px;font-weight:700;}
.cfg-row{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:8px;}
.cfg-label{font-size:12px;color:var(–muted);}
.cfg-val{font-size:12px;font-weight:700;color:var(–text);}
.avatar-cfg{width:64px;height:64px;border-radius:50%;background:linear-gradient(135deg,#5b5ef4,#a78bfa);display:flex;align-items:center;justify-content:center;font-size:26px;font-weight:900;color:#fff;margin:0 auto 10px;overflow:hidden;background-size:cover;background-position:center;cursor:pointer;border:2px solid #5b5ef4;}
.photo-btns{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;margin-bottom:4px;}
.photo-btn{background:var(–card);border:1px solid var(–border);border-radius:8px;padding:7px 14px;font-size:11px;color:var(–muted);cursor:pointer;font-family:‘Courier New’,monospace;transition:background .2s;}
.photo-btn:hover{background:var(–border);color:var(–text);}
.theme-btn{width:100%;background:linear-gradient(135deg,#2a2a2a,#333);border:1px solid var(–border);border-radius:10px;padding:12px;font-size:13px;font-weight:700;color:var(–text);font-family:‘Courier New’,monospace;cursor:pointer;transition:background .2s;}
.theme-btn:hover{background:var(–border);}
.pass-form{display:flex;flex-direction:column;gap:8px;}
.pass-err{font-size:11px;color:var(–red);min-height:14px;}
.cfg-input{width:100%;background:var(–card);border:1.5px solid var(–border);border-radius:9px;padding:9px 12px;font-size:12px;color:var(–text);font-family:‘Courier New’,monospace;outline:none;transition:border-color .2s;}
.cfg-input:focus{border-color:#5b5ef4;}
.cfg-save-btn{background:linear-gradient(135deg,#5b5ef4,#a78bfa);border:none;border-radius:9px;padding:10px;font-size:12px;font-weight:900;color:#fff;font-family:‘Courier New’,monospace;cursor:pointer;}
.danger-btn{background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.3);border-radius:9px;padding:10px;font-size:12px;font-weight:700;color:var(–red);font-family:‘Courier New’,monospace;cursor:pointer;width:100%;}
.danger-btn:hover{background:rgba(239,68,68,.2);}
.back-settings-btn{background:none;border:none;color:var(–dim);font-size:11px;cursor:pointer;font-family:‘Courier New’,monospace;text-decoration:underline;display:block;text-align:center;margin-top:6px;padding:4px;}

/* Buttons */
.btn{color:#fff;border:none;border-radius:10px;padding:11px 20px;font-size:12.5px;font-weight:700;cursor:pointer;font-family:‘Courier New’,monospace;transition:transform .1s,opacity .1s;}
.btn:hover{opacity:.88;}
.btn:active{transform:scale(.97);}
.btn-row{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;margin-top:13px;}
.win-icon{font-size:48px;margin-bottom:5px;}
.perfect-title{color:var(–gold);font-size:15px;font-weight:900;letter-spacing:2px;margin-bottom:4px;}
.gameover-icon{font-size:58px;}
.shaking{animation:shake .4s ease;}
.glitching{animation:glitch .35s ease;}
</style>

</head>
<body>

<!-- LOGIN -->

<div id="screen-login" class="screen active">
  <div class="card">
    <div class="login-icon">🎓</div>
    <div class="login-title">COLE OU PASSE</div>
    <div class="login-sub">Entre ou crie sua conta para jogar</div>
    <div class="ai-badge"><div class="ai-dot"></div>✦ IA Anthropic + Web Search</div>
    <div class="input-group">
      <div class="input-wrap"><input type="text" id="login-name" placeholder="Nome de usuário (ex: João)" maxlength="20" autocomplete="off"/></div>
      <div class="input-wrap"><input type="password" id="login-pass" placeholder="Senha (mín. 4 caracteres)" maxlength="30" autocomplete="off"/></div>
    </div>
    <button class="login-btn" onclick="doLogin()">🚀 ENTRAR / CADASTRAR</button>
    <div class="login-err" id="login-err"></div>
    <div class="login-hint">Primeiro acesso cria conta automaticamente.<br>Nomes são insensíveis a maiúsculas/minúsculas.<br>Dados salvos no navegador deste dispositivo.</div>
  </div>
</div>

<!-- MENU -->

<div id="screen-menu" class="screen">
  <div class="card">
    <div style="font-size:44px;margin-bottom:5px">📝</div>
    <div class="title">COLE OU PASSE</div>
    <div class="sub">Simulador de Desonestidade Acadêmica™</div>
    <div class="user-bar">
      <div class="avatar" id="avatar-menu"></div>
      <div class="user-info">
        <div class="user-name" id="user-display"></div>
        <div class="user-sub">✦ IA + Web Search ativo</div>
      </div>
      <div class="user-bar-btns">
        <button class="icon-btn" onclick="openSettings()" title="Configurações">⚙️</button>
        <button class="icon-btn" onclick="doLogout()" title="Sair">🚪</button>
      </div>
    </div>
    <div class="ai-badge"><div class="ai-dot"></div>✦ Questões geradas em tempo real com busca na web</div>
    <div class="desc">Responda sem ser pego pelo fiscal.<br>60s por questão. 100% = <b style="color:var(--gold)">★ PERFECT</b>!</div>
