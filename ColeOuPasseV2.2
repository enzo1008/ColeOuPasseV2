// ════════════════════════════════════════════════════════════
function openSettings(){renderSettings();showScreen(‘settings’);}

function renderSettings(){
const el=document.getElementById(‘cfg-name’);if(el)el.textContent=G.displayName||G.currentUser;
updateAvatarUI();
const t=getTheme();
const btn=document.getElementById(‘theme-toggle-btn’);
if(btn){btn.textContent=t===‘dark’?‘☀️ Mudar para Modo Claro’:‘🌙 Mudar para Modo Escuro’;}
const err=document.getElementById(‘cfg-pass-err’);
if(err){err.textContent=’’;err.style.color=‘var(–red)’;}
}

function handlePhotoUpload(e){
const file=e.target.files[0];
if(!file)return;
if(!file.type.match(/image/(png|jpeg|jpg|webp|gif)/i)&&!file.type.match(/application/pdf/i)){
alert(‘Use uma imagem PNG, JPG, WEBP ou GIF.’);return;
}
const reader=new FileReader();
reader.onload=ev=>{
let dataUrl=ev.target.result;
// If PDF, we can’t display it as image — reject
if(file.type.match(/pdf/i)){alert(‘PDFs não podem ser usados como foto de perfil. Use uma imagem.’);return;}
// Resize image for storage
const img=new Image();
img.onload=()=>{
const canvas=document.createElement(‘canvas’);
const MAX=200;
let w=img.width,h=img.height;
if(w>h){if(w>MAX){h=h*(MAX/w);w=MAX;}}else{if(h>MAX){w=w*(MAX/h);h=MAX;}}
canvas.width=w;canvas.height=h;
canvas.getContext(‘2d’).drawImage(img,0,0,w,h);
savePhoto(canvas.toDataURL(‘image/jpeg’,0.8));
};
img.src=dataUrl;
};
reader.readAsDataURL(file);
}

