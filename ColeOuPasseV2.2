function setStep(i,s){const el=document.getElementById(‘step-’+i);if(el)el.className=’step ’+s;}

// ════════════════════════════════════════════════════════════
// IA — Anthropic API + web_search
// ════════════════════════════════════════════════════════════
async function gerarQuestoesIA(nivel,qtd){
setStep(0,‘active’);
await delay(400);
let raw=’’;
try{
const resp=await fetch(‘https://api.anthropic.com/v1/messages’,{
method:‘POST’,
headers:{‘Content-Type’:‘application/json’},
body:JSON.stringify({
model:‘claude-sonnet-4-20250514’,
max_tokens:8000,
tools:[{type:‘web_search_20250305’,name:‘web_search’}],
messages:[{role:‘user’,content:AI_PROMPTS[nivel](qtd)}],
}),
});
if(!resp.ok) throw new Error(‘HTTP ‘+resp.status);
const data=await resp.json();
raw=(data.content||[]).filter(b=>b.type===‘text’).map(b=>b.text).join(’’);
}catch(e){console.warn(‘API failed:’,e);return null;}

setStep(0,‘done’);setStep(1,‘active’);
await delay(300);

let questoes=null;
try{
const clean=raw.replace(/`json\s*/gi,'').replace(/`\s*/g,’’).trim();
const m=clean.match(/{[\s\S]*}/);
if(!m) throw new Error(‘no JSON’);
const parsed=JSON.parse(m[0]);
questoes=parsed.questions||parsed.questoes||parsed;
if(!Array.isArray(questoes)) throw new Error(‘not array’);
}catch(e){console.warn(‘Parse failed:’,e);return null;}

setStep(1,‘done’);setStep(2,‘active’);
await delay(300);

const validas=[];
for(const q of questoes){
if(!q||typeof q.q!==‘string’||typeof q.a!==‘string’||!Array.isArray(q.o)||q.o.length<4) continue;
const aN=q.a.trim();
const oN=q.o.map(o=>String(o).trim());
let fi=oN.indexOf(aN);
if(fi===-1){fi=oN.findIndex(o=>o.toLowerCase()===aN.toLowerCase());if(fi!==-1)q.a=oN[fi];else{q.o[0]=aN;q.o=shuffle(q.o);}}
const uniq=[…new Set(q.o.map(o=>String(o).trim()))];
while(uniq.length<4) uniq.push(’—’);
q.o=uniq.slice(0,4);
validas.push({q:q.q.trim(),a:q.a.trim(),o:q.o,ai:true});
if(validas.length>=qtd) break;
}

setStep(2,‘done’);setStep(3,‘active’);
await delay(200);

if(validas.length<Math.ceil(qtd*0.5)){console.warn(‘Too few valid:’,validas.length);return null;}
const final=validas.map(q=>({…q,o:shuffle(q.o)}));
if(final.length<qtd){
const need=qtd-final.length;
const fb=nivel===‘rush’?getFallbackRush(need):shuffle(FALLBACK[nivel]||FALLBACK.facil).slice(0,need).map(shuffleOpts);
final.push(…fb);
}
setStep(3,‘done’);
await delay(150);
return final.slice(0,qtd);
}

