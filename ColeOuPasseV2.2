// INICIAR JOGO
// ════════════════════════════════════════════════════════════
async function startGame(nivel){
stopTimers();stopQTimer();
const names={facil:‘Fácil’,medio:‘Médio’,dificil:‘Difícil’,ultra:‘Ultra’,rush:‘Rush’};
const lt=document.getElementById(‘loading-text’);
if(lt) lt.textContent=‘Gerando prova de ‘+names[nivel]+’ com IA e busca na web…’;
setStep(0,‘active’);setStep(1,‘wait’);setStep(2,‘wait’);setStep(3,‘wait’);
showScreen(‘loading’);

let questions=null,aiOk=false;
try{questions=await gerarQuestoesIA(nivel,CONFIG[nivel].qtd);aiOk=questions!==null;}catch(e){console.warn(‘IA err:’,e);}
if(!aiOk){
questions=nivel===‘rush’?getFallbackRush(CONFIG[nivel].qtd):shuffle(FALLBACK[nivel]||FALLBACK.facil).slice(0,CONFIG[nivel].qtd).map(shuffleOpts);
showToast(‘⚠️ Usando banco local (IA indisponível)’,‘warn’,3000);
}

G={…G,phase:‘game’,nivel,questions,qIdx:0,score:0,suspicion:0,
fiscalLooking:false,cheatOpen:false,cheatUsed:false,cheatTotal:0,
cheatCount:0,correctCount:0,history:[],answering:false,answerResult:null,
eyeState:‘normal’,aiGenerated:aiOk,gameStartTime:Date.now(),totalGameTime:0};

showScreen(‘game’);renderGame();startTimers();
if(!CONFIG[nivel].noTimer) startQTimer();
}
function retryGame(){startGame(G.nivel);}

// ════════════════════════════════════════════════════════════
// TIMER DE QUESTÃO (60s)
// ════════════════════════════════════════════════════════════
let qTimeLeft=QUESTION_TIME;

function startQTimer(){
stopQTimer();
const c=cfg();
if(c&&c.noTimer){
const tb=document.getElementById(‘timer-bar’);if(tb)tb.style.display=‘none’;
return;
}
document.getElementById(‘timer-bar’).style.display=‘flex’;
qTimeLeft=QUESTION_TIME;
updateTimerUI();
qTimer=setInterval(()=>{
if(G.phase!==‘game’||G.answering) return;
qTimeLeft–;
updateTimerUI();
if(qTimeLeft<=0){
clearInterval(qTimer);qTimer=null;
timeOut();
}
},1000);
}
function stopQTimer(){clearInterval(qTimer);qTimer=null;}

function updateTimerUI(){
const pct=(qTimeLeft/QUESTION_TIME)*100;
const color=qTimeLeft>30?‘var(–green)’:qTimeLeft>10?‘var(–yellow)’:‘var(–red)’;
const fill=document.getElementById(‘timer-fill’);
const num=document.getElementById(‘timer-num’);
const bar=document.getElementById(‘timer-bar’);
if(fill){fill.style.width=pct+’%’;fill.style.background=color;}
if(num){num.textContent=qTimeLeft+‘s’;num.style.color=color;}
if(bar){
if(qTimeLeft<=10&&!bar.classList.contains(‘timer-urgent’)) bar.classList.add(‘timer-urgent’);
else if(qTimeLeft>10) bar.classList.remove(‘timer-urgent’);
}
}

function timeOut(){
const c2=cfg();if(!c2||c2.noTimer)return;
if(G.answering||G.phase!==‘game’) return;
const q=G.questions[G.qIdx];
G.answerResult={chosen:null,correct:false,answer:q.a};
G.cheatOpen=false;G.answering=true;
document.getElementById(‘cheat-card’).classList.remove(‘visible’);
G.history.push({q:q.q,chosen:null,correct:false,answer:q.a,used:G.cheatUsed,options:q.o,ai:!!q.ai,timeout:true});
updateCounters();renderOptions();updateCheatBtn();
showToast(’⏱ Tempo esgotado! Era: ’+escH(q.a),‘danger’,2000);
setTimeout(()=>{
G.answerResult=null;G.cheatUsed=false;G.cheatOpen=false;G.answering=false;
const c=cfg();
if(G.qIdx+1>=c.qtd) endGame(‘complete’,G.correctCount);
else{G.qIdx++;renderGame();if(!c.noTimer) startQTimer();}
},2000);
}

// ════════════════════════════════════════════════════════════
// TIMERS (fiscal + decay)
// ════════════════════════════════════════════════════════════
function startTimers(){
const c=cfg();
const schedule=()=>{fiscalTimer=setTimeout(()=>{doFiscalLook();if(G.phase===‘game’)schedule();},c.fiscalMin+Math.random()*c.fiscalExtra);};
schedule();
decayTimer=setInterval(()=>{if(G.phase!==‘game’)return;G.suspicion=Math.max(0,G.suspicion-c.decayRate);updateSuspBar();},300);
}
function stopTimers(){clearTimeout(fiscalTimer);clearInterval(decayTimer);fiscalTimer=decayTimer=null;}

// ════════════════════════════════════════════════════════════
// FISCAL
// ════════════════════════════════════════════════════════════
function doFiscalLook(){
if(G.phase!==‘game’)return;const c=cfg();
G.fiscalLooking=true;G.eyeState=‘looking’;updateFiscalUI();triggerGlitch();
setTimeout(()=>{
if(G.phase!==‘game’)return;
if(G.cheatOpen){
G.suspicion=Math.min(100,G.suspicion+c.suspGain);updateSuspBar();
if(G.suspicion>=100){G.eyeState=‘caught’;updateFiscalUI();endGame(‘caught’);}
else{G.eyeState=‘suspicious’;updateFiscalUI();showToast(‘⚠️ O fiscal te viu com a cola!’,‘danger’,1600);triggerShake();setTimeout(()=>{G.eyeState=‘normal’;updateFiscalUI();},1500);}
}else{G.eyeState=‘normal’;updateFiscalUI();}
G.fiscalLooking=false;updateFiscalBanner();
},c.lookDuration);
}

// ════════════════════════════════════════════════════════════
// RENDER JOGO
// ════════════════════════════════════════════════════════════
function renderGame(){
const c=cfg(),q=G.questions[G.qIdx],isRush=G.nivel===‘rush’;
const sn=document.getElementById(‘stat-nivel’);sn.textContent=c.emoji+’ ‘+c.label;sn.style.color=c.color;sn.style.fontSize=‘11px’;
const cw=document.getElementById(‘stat-colas-wrap’);
if(isRush){cw.style.display=‘flex’;const left=c.maxCheats-G.cheatTotal;const sc=document.getElementById(‘stat-colas’);sc.textContent=left;sc.style.color=left===0?‘var(–red)’:‘var(–yellow)’;}
else cw.style.display=‘none’;
const gw=document.getElementById(‘game-wrap’);gw.style.setProperty(’–lvl-color’,c.color);gw.style.setProperty(’–lvl-bg’,c.bg);
updateCounters();updateSuspBar();updateFiscalUI();updateFiscalBanner();
const qBox=document.getElementById(‘q-box’);qBox.style.borderColor=c.color+‘55’;
const ql=document.getElementById(‘q-label’);ql.textContent=`Questão ${G.qIdx+1} — ${c.label}`;ql.style.color=c.color;
document.getElementById(‘q-text’).textContent=q?q.q:’’;
const aitag=document.getElementById(‘q-ai-tag’);if(aitag)aitag.style.display=(q&&q.ai)?‘inline-flex’:‘none’;
document.getElementById(‘cheat-answer’).textContent=‘→ ‘+(q?q.a:’’);
document.getElementById(‘cheat-card’).classList.remove(‘visible’);
renderDots();renderOptions();updateCheatBtn();
}

function updateCounters(){
const c=cfg();
document.getElementById(‘stat-questao’).innerHTML=`${G.qIdx+1}<span style="color:var(--dim)">/${c.qtd}</span>`;
document.getElementById(‘stat-pontos’).textContent=G.score;
}

function renderDots(){
const c=cfg(),row=document.getElementById(‘dot-row’);row.innerHTML=’’;
const max=Math.min(c.qtd,40);
for(let i=0;i<max;i++){
const d=document.createElement(‘div’);d.className=‘dot’;
if(i<G.qIdx) d.style.background=‘var(–green)’;
else if(i===G.qIdx){d.style.background=c.color;d.style.boxShadow=`0 0 6px ${c.color}`;}
else d.style.background=’#252525’;
row.appendChild(d);
}
if(c.qtd>40){const sp=document.createElement(‘span’);sp.className=‘dot-extra’;sp.textContent=`+${c.qtd-40}`;row.appendChild(sp);}
}

function renderOptions(){
const c=cfg(),q=G.questions[G.qIdx];
const grid=document.getElementById(‘opt-grid’);grid.innerHTML=’’;
if(!q)return;
[‘A’,‘B’,‘C’,‘D’].forEach((letter,i)=>{
const opt=q.o[i];
const btn=document.createElement(‘button’);btn.className=‘opt-btn’;btn.disabled=G.answering;
if(G.answering&&G.answerResult){
if(opt===G.answerResult.answer) btn.classList.add(‘correct’);
else if(opt===G.answerResult.chosen) btn.classList.add(‘wrong’);
}
btn.innerHTML=`<span class="opt-letter">${letter}</span>${escH(opt||'—')}`;
if(!G.answering){
btn.addEventListener(‘mouseover’,()=>{if(!btn.classList.contains(‘correct’)&&!btn.classList.contains(‘wrong’)){btn.style.borderColor=c.color;btn.style.background=c.bg;}});
btn.addEventListener(‘mouseout’,()=>{if(!btn.classList.contains(‘correct’)&&!btn.classList.contains(‘wrong’)){btn.style.borderColor=’#2a2a2a’;btn.style.background=’#1c1c1c’;}});
}
btn.onclick=()=>answer(opt);
grid.appendChild(btn);
});
}

function updateSuspBar(){const pct=Math.min(100,G.suspicion);const color=pct<40?‘var(–green)’:pct<70?‘var(–yellow)’:‘var(–red)’;const f=document.getElementById(‘susp-fill’);const p=document.getElementById(‘susp-pct’);if(f){f.style.width=pct+’%’;f.style.background=color;}if(p){p.textContent=Math.round(pct)+’%’;p.style.color=color;}}
function updateFiscalUI(){const map={normal:‘😐’,looking:‘👀’,suspicious:‘🤨’,caught:‘😡’};const el=document.getElementById(‘stat-fiscal’);if(el)el.textContent=map[G.eyeState]||‘😐’;}
function updateFiscalBanner(){const b=document.getElementById(‘fiscal-banner’);if(!b)return;if(G.fiscalLooking){b.style.background=‘rgba(239,68,68,0.14)’;b.style.borderColor=‘var(–red)’;b.style.color=’#fca5a5’;b.textContent=‘👁️ CUIDADO — FISCAL OLHANDO!’;}else{b.style.background=‘rgba(34,197,94,0.07)’;b.style.borderColor=’#1a3d26’;b.style.color=’#4ade80’;b.textContent=‘✅ Fiscal distraído — seguro agora’;}}

function updateCheatBtn(){
const c=cfg(),btn=document.getElementById(‘cheat-btn’);if(!btn)return;
const cheatsLeft=c.maxCheats!=null?c.maxCheats-G.cheatTotal:null;
const disabled=G.answering||(G.cheatUsed&&!G.cheatOpen)||(cheatsLeft===0&&!G.cheatOpen);
btn.disabled=disabled;btn.style.opacity=disabled?‘0.35’:‘1’;btn.style.cursor=disabled?‘not-allowed’:‘pointer’;
if(G.cheatOpen){btn.textContent=‘🙈 ESCONDER COLA’;btn.classList.add(‘open’);}
else{btn.textContent=‘📋 VER COLA’+(G.nivel===‘rush’&&cheatsLeft!=null?` (${cheatsLeft} left)`:’’);btn.classList.remove(‘open’);}
}

// ════════════════════════════════════════════════════════════
// COLA
// ════════════════════════════════════════════════════════════
function toggleCheat(){
if(G.answering)return;const c=cfg();
const cheatsLeft=c.maxCheats!=null?c.maxCheats-G.cheatTotal:null;
if(!G.cheatOpen){
if(G.cheatUsed)return;
if(cheatsLeft===0){showToast(‘🚫 Limite de ‘+c.maxCheats+’ colas atingido!’,‘danger’);return;}
if(G.fiscalLooking){G.suspicion=Math.min(100,G.suspicion+c.suspGainNoCheat);updateSuspBar();if(G.suspicion>=100){endGame(‘caught’);return;}showToast(‘🚨 Fiscal olhando! Não deu!’,‘danger’);triggerShake();return;}
G.cheatOpen=true;G.cheatUsed=true;G.cheatCount++;G.cheatTotal++;
const rem=c.maxCheats!=null?c.maxCheats-G.cheatTotal:null;
showToast(rem!=null?`📋 Cola! (${rem} restantes)`:‘📋 Cola aberta!’,‘warn’,2000);
}else G.cheatOpen=false;
document.getElementById(‘cheat-card’).classList.toggle(‘visible’,G.cheatOpen);
updateCheatBtn();
if(G.nivel===‘rush’){const left=CONFIG.rush.maxCheats-G.cheatTotal;const sc=document.getElementById(‘stat-colas’);if(sc){sc.textContent=left;sc.style.color=left===0?‘var(–red)’:‘var(–yellow)’;}}
}

// ════════════════════════════════════════════════════════════
// RESPOSTA
// ════════════════════════════════════════════════════════════
function answer(opt){
if(G.answering)return;
stopQTimer();
const c=cfg(),q=G.questions[G.qIdx];
const correct=opt===q.a;
const pts=correct?(G.cheatUsed?c.pts.cheat:c.pts.clean):0;
const newCorrect=correct?G.correctCount+1:G.correctCount;
G.answerResult={chosen:opt,correct,answer:q.a};G.cheatOpen=false;G.answering=true;
document.getElementById(‘cheat-card’).classList.remove(‘visible’);
if(correct){G.score+=pts;G.correctCount=newCorrect;}
G.history.push({q:q.q,chosen:opt,correct,answer:q.a,used:G.cheatUsed,options:q.o,ai:!!q.ai});
updateCounters();renderOptions();updateCheatBtn();
showToast(correct?`✅ Correto! +${pts} pts`:`❌ Errou! Era: ${escH(q.a)}`,correct?‘ok’:‘danger’,2000);
setTimeout(()=>{
G.answerResult=null;G.cheatUsed=false;G.cheatOpen=false;G.answering=false;
if(G.qIdx+1>=c.qtd) endGame(‘complete’,newCorrect);
else{G.qIdx++;renderGame();if(!c.noTimer) startQTimer();}
},2000);
}

// ════════════════════════════════════════════════════════════
// FIM DO JOGO
// ════════════════════════════════════════════════════════════
function endGame(reason,finalCorrect){
stopTimers();stopQTimer();
const c=cfg();const correct=finalCorrect!=null?finalCorrect:G.correctCount;
G.totalGameTime=Date.now()-G.gameStartTime;
const pct=Math.round((correct/c.qtd)*100);
if(reason===‘complete’&&pct===100){G.perfects[G.nivel]=true;savePerfect(G.nivel);}
G.phase=reason===‘caught’?‘gameover’:‘win’;
if(reason===‘caught’){renderGameOver();showScreen(‘gameover’);}
else{
addLBEntry(G.nivel,G.score,G.totalGameTime,pct);
renderWin(correct);showScreen(‘win’);
}
}

function renderGameOver(){
const c=cfg();
document.getElementById(‘go-stats’).innerHTML=` <div class="stat-item"><span>Nível</span><b style="color:${c.color}">${c.label}</b></div> <div class="stat-item"><span>Pontuação</span><b>${G.score}</b></div> <div class="stat-item"><span>Questões</span><b>${G.qIdx}/${c.qtd}</b></div> <div class="stat-item"><span>Acertos</span><b>${G.correctCount}</b></div>`;
}

function renderWin(correct){
const c=cfg(),qtd=c.qtd,maxScore=qtd*10;
const pct=Math.round((correct/qtd)*100);
const g=usGrade(pct),isPerfect=pct===100;
const wc=document.getElementById(‘win-card’);
wc.style.borderColor=isPerfect?‘var(–gold)’:‘var(–green)’;
wc.style.boxShadow=isPerfect?‘0 0 28px rgba(255,215,0,0.45)’:‘none’;
document.getElementById(‘win-icon’).textContent=isPerfect?‘🏆’:‘🎓’;
document.getElementById(‘win-title’).style.color=isPerfect?‘var(–gold)’:‘var(–green)’;
document.getElementById(‘win-title’).textContent=‘PROVA CONCLUÍDA!’;
document.getElementById(‘perfect-line’).style.display=isPerfect?‘block’:‘none’;
document.getElementById(‘grade-card-wrap’).innerHTML=` <div class="grade-card" style="border-color:${g.color};background:${g.color}18"> <div class="grade-letter" style="color:${g.color}">${g.letter}</div> <div class="grade-info"> <span>GPA: <b style="color:${g.color}">${g.gpa}</b></span> <span>Score: <b style="color:${g.color}">${pct}%</b></span> <span class="grade-label" style="color:${g.color}">${g.label}</span> </div> </div>`;
const scales=[{r:‘A+ (100%)’,min:100,c:’#ffd700’},{r:‘A (93–99%)’,min:93,c:’#22c55e’},{r:‘B (80–89%)’,min:80,c:’#86efac’},{r:‘C (70–79%)’,min:70,c:’#f59e0b’},{r:‘D (60–69%)’,min:60,c:’#ef4444’},{r:‘F (<60%)’,min:0,c:’#7f1d1d’}];
document.getElementById(‘scale-wrap’).innerHTML=scales.map(s=>`<div class="scale-item" style="border-color:${s.c}55;background:${pct>=s.min?s.c+'33':'#1a1a1a'}"><span style="color:${s.c}">${s.r}</span></div>`).join(’’);
const aiCount=G.history.filter(h=>h.ai).length;
document.getElementById(‘win-stats’).innerHTML=` <div class="stat-item"><span>Nível</span><b style="color:${c.color}">${c.label}</b></div> <div class="stat-item"><span>Pontuação</span><b>${G.score}/${maxScore}</b></div> <div class="stat-item"><span>Acertos</span><b>${correct}/${qtd} (${pct}%)</b></div> <div class="stat-item"><span>Tempo total</span><b style="color:var(--yellow)">${fmtTime(G.totalGameTime)}</b></div> <div class="stat-item"><span>Colas usadas</span><b>${G.cheatCount}${c.maxCheats?'/'+c.maxCheats:''}</b></div> <div class="stat-item"><span>Fonte</span><b style="color:#a78bfa">${aiCount>0?'✦ IA ('+aiCount+' questões)':'📦 Banco local'}</b></div>`;
document.getElementById(‘win-retry-btn’).style.background=isPerfect?’#b8860b’:‘var(–green)’;
renderLeaderboard(G.nivel,G.score,G.totalGameTime);
renderGabarito();
}

function renderGabarito(){
const list=document.getElementById(‘gab-list’);list.innerHTML=’’;
G.history.forEach((h,i)=>{
const wrap=document.createElement(‘div’);
const row=document.createElement(‘button’);
row.className=‘gab-row ‘+(h.correct?‘correct-row’:‘wrong-row’);
const timeoutTag=h.timeout?’<span class="gab-ai" title="Tempo esgotado">⏱</span>’:’’;
const aiTag=h.ai?’<span class="gab-ai" title="IA">✦</span>’:’’;
row.innerHTML=`<span class="gab-num">Q${i+1}</span><span class="gab-q">${escH(h.q)}</span>${aiTag}${timeoutTag}<span>${h.correct?'✅':'❌'}</span>${h.used?'<span class="gab-cheat">🅲</span>':''}<span class="gab-arr">▼</span>`;
const detail=document.createElement(‘div’);detail.className=‘gab-detail’;
const letters=[‘A’,‘B’,‘C’,‘D’];
h.options.forEach((opt,oi)=>{
const isC=opt===h.answer,isW=opt===h.chosen&&!isC;
const d=document.createElement(‘div’);d.className=‘gab-opt’+(isC?’ correct-opt’:isW?’ wrong-opt’:’’);
d.innerHTML=`<span class="gab-opt-letter">${letters[oi]}</span><span style="flex:1">${escH(opt)}</span>${isC?'<span class="gab-opt-tag">✓ Correta</span>':''}${isW?'<span class="gab-opt-tag">✗ Sua resposta</span>':''}`;
detail.appendChild(d);
});
row.onclick=()=>{const open=detail.classList.contains(‘open’);detail.classList.toggle(‘open’,!open);row.classList.toggle(‘expanded’,!open);const arr=row.querySelector(’.gab-arr’);if(arr)arr.textContent=open?‘▼’:‘▲’;};
wrap.appendChild(row);wrap.appendChild(detail);list.appendChild(wrap);
});
}

// ════════════════════════════════════════════════════════════
// EFEITOS
// ════════════════════════════════════════════════════════════
function triggerShake(){const gw=document.getElementById(‘game-wrap’);if(!gw)return;gw.classList.add(‘shaking’);setTimeout(()=>gw.classList.remove(‘shaking’),500);}
function triggerGlitch(){const gw=document.getElementById(‘game-wrap’);if(!gw)return;gw.classList.add(‘glitching’);setTimeout(()=>gw.classList.remove(‘glitching’),350);}
function showToast(text,type,ms=1800){
clearTimeout(toastTimer);const t=document.getElementById(‘toast’);if(!t)return;
const colors={ok:‘var(–green)’,danger:‘var(–red)’,warn:‘var(–yellow)’,info:’#6366f1’};
t.textContent=text;t.style.color=colors[type]||‘var(–text)’;t.style.borderColor=colors[type]||’#333’;t.style.display=‘block’;
toastTimer=setTimeout(()=>{t.style.display=‘none’;},ms);
}

// ════════════════════════════════════════════════════════════
// ENTER KEY no login
// ════════════════════════════════════════════════════════════
[‘login-name’,‘login-pass’].forEach(id=>{
const el=document.getElementById(id);
if(el) el.addEventListener(‘keydown’,e=>{if(e.key===‘Enter’) doLogin();});
});

// ════════════════════════════════════════════════════════════
// INIT
// ════════════════════════════════════════════════════════════
if(loadUserSession()) renderMenu();
else showScreen(‘login’);

// ════ PATCH renderMenu ════
const _origRenderMenu = typeof renderMenu === ‘function’ ? renderMenu : null;
function renderMenu(){
document.getElementById(‘user-display’).textContent = G.displayName || G.currentUser || ‘’;
updateAvatarUI();
const grid = document.getElementById(‘level-grid’);
grid.innerHTML = ‘’;
LEVEL_ORDER.forEach(key => {
const c = CONFIG[key], isPerfect = G.perfects[key], isRush = key === ‘rush’;
const btn = document.createElement(‘button’);
btn.className = ‘level-btn’ + (isRush?’ rush’:’’) + (isPerfect?’ perfect’:’’);
btn.style.borderColor = isPerfect ? ‘var(–gold)’ : c.color;
btn.style.background = isPerfect ? ‘rgba(255,215,0,0.08)’ : c.bg;
btn.innerHTML = `<div class="level-name"><span>${c.emoji}</span><span style="color:${isPerfect?'var(--gold)':c.color}">${c.label}</span>${isPerfect?'<span class="perfect-badge">★ PERFECT</span>':''}</div><div class="level-desc" style="color:${isPerfect?'#d4af37':'var(--muted)'}">${c.desc}</div>${isRush?'<div style="font-size:9px;color:var(--orange);font-weight:700;margin-top:2px">⚡ Mix total • Máx. 15 colas</div>':''}`;
btn.onclick = () => startGame(key);
grid.appendChild(btn);
});
showScreen(‘menu’);
}
function goMenu(){stopTimers();stopQTimer();G.phase=‘menu’;renderMenu();}

// ════ ENTER KEY no login ════
[‘login-name’,‘login-pass’].forEach(id=>{
const el=document.getElementById(id);
if(el) el.addEventListener(‘keydown’,e=>{if(e.key===‘Enter’)doLogin();});
});

// ════ INIT ════
applyTheme(getTheme());
if(loadUserSession()) renderMenu();
else showScreen(‘login’);
</script>

